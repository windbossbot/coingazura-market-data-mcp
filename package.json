{
  "name": "coingazura-market-data-mcp",
  "version": "0.1.3",
  "description": "Read-only MCP server for COINGAZURA live market mood, stable exit risk, and yield candidate snapshots.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "coingazura-market-data-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LAUNCHGUIDE.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "release:check": "npm run build && npm pack --dry-run"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "crypto",
    "market-data",
    "yield",
    "coingazura",
    "risk",
    "stablecoin"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/windbossbot/coingazura-market-data-mcp.git"
  },
  "homepage": "https://github.com/windbossbot/coingazura-market-data-mcp",
  "bugs": {
    "url": "https://github.com/windbossbot/coingazura-market-data-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "tsx": "^4.20.0",
    "typescript": "^5.8.3"
  }
}
